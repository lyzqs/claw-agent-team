# CigarButtInvest 定时任务配置
# 香港联交所交易日每日上午 9:30 自动执行

# 执行时间（北京时间）
SCREENING_TIME="09:30"

# 是否仅在交易日运行
TRADING_DAY_ONLY=true

# 试运行模式（不执行实际筛选）
DRY_RUN=false

# 最大重试次数
MAX_RETRIES=3

# 重试基础延迟（秒）
RETRY_BASE_DELAY=60

# 日志目录
LOG_DIR="logs"

# 数据缓存目录
CACHE_DIR="data/cache"

# 报告输出目录
REPORT_DIR="docs/daily_runs"